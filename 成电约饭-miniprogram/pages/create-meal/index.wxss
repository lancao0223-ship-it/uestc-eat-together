.page-create {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 160rpx;
}

.form-card {
  background: var(--surface);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
  margin: 24rpx;
  padding: 8rpx 0;
}

.form-group {
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid var(--border);
}

.form-group:last-child {
  border-bottom: none;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 16rpx;
}

.form-label.required::after {
  content: '*';
  color: var(--danger);
  margin-left: 8rpx;
}

.form-input {
  height: 72rpx;
  background: var(--bg);
  border-radius: var(--radius-md);
  padding: 0 24rpx;
  font-size: 28rpx;
  color: var(--text);
}

.picker-value {
  height: 72rpx;
  background: var(--bg);
  border-radius: var(--radius-md);
  padding: 0 24rpx;
  font-size: 28rpx;
  color: var(--text);
  display: flex;
  align-items: center;
}

.picker-value.placeholder {
  color: var(--text-muted);
}

.form-textarea {
  width: 100%;
  height: 160rpx;
  background: var(--bg);
  border-radius: var(--radius-md);
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: var(--text);
  box-sizing: border-box;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
}

.tag-selector {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-option {
  padding: 12rpx 24rpx;
  background: var(--bg);
  border-radius: var(--radius-full);
  font-size: 26rpx;
  color: var(--text-secondary);
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.tag-selected {
  background: var(--primary-light);
  color: var(--primary);
  border-color: var(--primary);
  font-weight: 600;
}

.safety-group {
  background: #FAFAFA;
  border-radius: 0 0 var(--radius-lg) var(--radius-lg);
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.switch-row:last-child {
  border-bottom: none;
}

.switch-info {
  flex: 1;
}

.switch-title {
  display: block;
  font-size: 28rpx;
  color: var(--text);
  font-weight: 500;
}

.switch-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 4rpx;
}

.submit-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  background: var(--surface);
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.06);
}

.submit-btn {
  width: 100%;
}
