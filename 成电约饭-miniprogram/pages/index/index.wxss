.page-container {
  min-height: 100vh;
  background: var(--bg);
}

/* Campus Bar */
.campus-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: var(--surface);
}

.campus-picker {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.campus-icon {
  font-size: 28rpx;
}

.campus-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
}

.campus-arrow {
  font-size: 20rpx;
  color: var(--text-muted);
  margin-left: 4rpx;
}

.filter-btn {
  padding: 8rpx 20rpx;
  background: var(--bg);
  border-radius: var(--radius-full);
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* Tab Bar */
.tab-bar {
  display: flex;
  background: var(--surface);
  padding: 0 32rpx;
  border-bottom: 1rpx solid var(--border);
  gap: 48rpx;
}

.tab-item {
  padding: 24rpx 0;
  font-size: 30rpx;
  color: var(--text-muted);
  position: relative;
  font-weight: 500;
}

.tab-active {
  color: var(--primary);
  font-weight: 700;
}

.tab-active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: var(--primary);
  border-radius: var(--radius-full);
}

/* Filter Panel */
.filter-panel {
  background: var(--surface);
  padding: 0 32rpx;
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease;
}

.filter-panel.show {
  max-height: 200rpx;
  padding: 16rpx 32rpx;
  border-bottom: 1rpx solid var(--border);
}

.filter-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
}

.filter-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* Feed */
.feed-scroll {
  height: calc(100vh - 180rpx);
}

.feed-list {
  padding: 24rpx;
}

/* Meal Card */
.meal-card-wrapper {
  background: var(--surface);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
  padding: 28rpx;
  margin-bottom: 24rpx;
  transition: transform 0.15s ease;
}

.meal-card-wrapper:active {
  transform: scale(0.98);
}

.host-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.host-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-full);
  background: var(--bg);
}

.host-meta {
  flex: 1;
}

.host-name-line {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.host-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
}

.gender-badge {
  width: 32rpx;
  height: 32rpx;
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
}

.gender-badge.female {
  background: #FCE7F3;
  color: var(--female-only);
}

.gender-badge.male {
  background: #DBEAFE;
  color: var(--primary);
}

.health-badge {
  padding: 4rpx 12rpx;
  background: #D1FAE5;
  color: #059669;
  border-radius: var(--radius-sm);
  font-size: 20rpx;
  font-weight: 500;
}

.host-sub {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.credit-badge {
  padding: 4rpx 12rpx;
  border-radius: var(--radius-sm);
  font-size: 20rpx;
  font-weight: 500;
}

.credit-badge.high {
  background: #D1FAE5;
  color: #059669;
}

.credit-badge.mid {
  background: #FEF3C7;
  color: #D97706;
}

.credit-badge.low {
  background: #FEE2E2;
  color: #DC2626;
}

.time-ago {
  font-size: 22rpx;
  color: var(--text-muted);
}

/* Meal Content */
.meal-content {
  margin-bottom: 20rpx;
}

.meal-note {
  font-size: 28rpx;
  color: var(--text);
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.info-grid {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.info-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.info-icon {
  font-size: 28rpx;
  width: 36rpx;
  text-align: center;
}

.info-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.cost-tag {
  padding: 6rpx 16rpx;
  background: var(--primary-light);
  color: var(--primary);
  border-radius: var(--radius-sm);
  font-size: 22rpx;
  font-weight: 600;
}

.cost-tag.treat {
  background: var(--cta-light);
  color: var(--cta);
}

/* Action */
.meal-action {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--border);
}

.spots-left {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.spots-num {
  color: var(--cta);
  font-weight: 700;
}

.join-btn {
  padding: 16rpx 40rpx;
}

/* Group Card */
.group-card {
  padding: 24rpx;
}

.group-hint {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 24rpx;
  background: #EFF6FF;
  border-radius: var(--radius-md);
  margin-bottom: 24rpx;
}

.hint-icon {
  font-size: 28rpx;
}

.hint-text {
  font-size: 26rpx;
  color: var(--primary);
}

.group-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.group-body {
  margin-bottom: 16rpx;
}

.group-merchant {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 8rpx;
}

.group-item {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.group-progress {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.progress-bar {
  flex: 1;
  height: 12rpx;
  background: var(--bg);
  border-radius: var(--radius-full);
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary), var(--secondary));
  border-radius: var(--radius-full);
  transition: width 0.5s ease;
}

.progress-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 500;
  min-width: 100rpx;
  text-align: right;
}

/* FAB */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 160rpx;
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(135deg, var(--primary), var(--secondary));
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-lg);
  z-index: 100;
  transition: transform 0.15s ease;
}

.fab:active {
  transform: scale(0.92);
}

.fab-icon {
  color: #fff;
  font-size: 48rpx;
  font-weight: 300;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  text-align: center;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-muted);
}

/* Loading Skeleton */
.loading-footer {
  padding: 40rpx;
}

.skeleton-line {
  height: 32rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e8e8e8 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: var(--radius-sm);
}
