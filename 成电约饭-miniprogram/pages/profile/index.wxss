.page-profile {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 48rpx;
}

/* Profile Header */
.profile-header {
  background: linear-gradient(135deg, var(--primary), var(--secondary));
  padding: 48rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.profile-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: var(--radius-full);
  border: 4rpx solid rgba(255,255,255,0.3);
  background: var(--bg);
}

.profile-info {
  flex: 1;
}

.profile-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
  display: block;
}

.profile-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
  margin-bottom: 16rpx;
}

.meta-dot {
  opacity: 0.6;
}

.profile-badges {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.profile-badges .gender-badge {
  width: 36rpx;
  height: 36rpx;
  background: rgba(255,255,255,0.25);
  color: #fff;
}

.profile-badges .credit-badge {
  background: rgba(255,255,255,0.25);
  color: #fff;
}

/* Stats */
.stats-card {
  background: var(--surface);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
  margin: -32rpx 24rpx 24rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-around;
  position: relative;
  z-index: 2;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--text);
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-muted);
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: var(--border);
}

/* Profile Cards */
.profile-card {
  background: var(--surface);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
  margin: 0 24rpx 24rpx;
  padding: 28rpx;
}

.card-header {
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text);
}

.card-subtitle {
  font-size: 22rpx;
  color: var(--text-muted);
  display: block;
  margin-top: 4rpx;
}

.edit-link {
  font-size: 26rpx;
  color: var(--primary);
  font-weight: 500;
}

/* Health Report */
.health-status {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.health-icon-box {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.health-icon-box.success {
  background: #D1FAE5;
}

.health-icon-box.muted {
  background: var(--bg);
}

.health-icon {
  font-size: 36rpx;
}

.health-info {
  flex: 1;
}

.health-status-text {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--success);
  display: block;
  margin-bottom: 8rpx;
}

.health-date, .health-expiry {
  font-size: 24rpx;
  color: var(--text-muted);
  display: block;
  margin-top: 4rpx;
}

.health-actions {
  display: flex;
  gap: 16rpx;
}

.btn-outline {
  flex: 1;
  padding: 20rpx;
  background: var(--bg);
  color: var(--text-secondary);
  border-radius: var(--radius-md);
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.btn-outline.danger {
  color: var(--danger);
  background: #FEF2F2;
}

.health-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 32rpx 16rpx;
}

.health-empty-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
  margin: 16rpx 0 8rpx;
}

.health-empty-desc {
  font-size: 26rpx;
  color: var(--text-muted);
  line-height: 1.5;
  margin-bottom: 24rpx;
}

.upload-btn {
  width: 80%;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.privacy-hint {
  font-size: 22rpx;
  color: var(--text-muted);
}

/* Menu */
.menu-card {
  padding: 8rpx 0;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid var(--border);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: var(--bg);
}

.menu-icon {
  font-size: 32rpx;
  width: 48rpx;
  text-align: center;
  margin-right: 16rpx;
}

.menu-label {
  flex: 1;
  font-size: 30rpx;
  color: var(--text);
}

.menu-arrow {
  font-size: 32rpx;
  color: var(--text-muted);
}

/* Footer */
.profile-footer {
  text-align: center;
  padding: 32rpx;
  font-size: 24rpx;
  color: var(--text-muted);
}
